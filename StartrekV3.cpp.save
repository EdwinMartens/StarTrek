/** \brief
 *  Timer event handler
 *  \param ALLEGRO_TIMER_EVENT * timer_event
 *
 */
void Timer(ALLEGRO_TIMER_EVENT * timer_event)
{
	if (!g_vGameState.empty())
    {
        switch(g_vGameState.back())
        {
            case GS_INTRO:
            DoIntro();
            break;

            case GS_MENU:

            break;

            case GS_GAME:
            GameCycle();
            break;
        }
    }
	else
    {
        g_blQuit = true;
    }

}




